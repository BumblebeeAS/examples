<?xml version="1.0"?>
<package format="3">
  <name>ardusub_interface</name>
  <version>1.0.0</version>
  <description>ArduSub SITL and MAVROS interface for BlueROV-style simulations</description>
  <maintainer email="maintainer@example.com">maintainer</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <depend>geometry_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>tf2_ros</depend>

  <exec_depend>ament_index_python</exec_depend>
  <exec_depend>launch_ros</exec_depend>
  <exec_depend>mavros</exec_depend>
  <exec_depend>mavros_extras</exec_depend>
  <exec_depend>mavros_msgs</exec_depend>
  <exec_depend>dave_interfaces</exec_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
